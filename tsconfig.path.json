{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@assets/*": ["src/assets/*"],
      "@images/*": ["src/assets/images/*"],
      "@shared/*": ["src/shared/*"],
      "@fonts/*": ["src/assets/fonts/*"],
      "@components/*": ["src/components/*"],
      "@enums/*": ["src/enums/*"],
      "@api/*": ["src/api/*"],
      "@hooks/*": ["src/hooks/*"],
      "@validations/*": ["src/validations/*"],
      "@helpers/*": ["src/helpers/*"],
      "@icons/*": ["src/icons/*"]
    }
  }
}
