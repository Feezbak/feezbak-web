{
  "ci": {
    "collect": {
      "url": ["http://localhost:5000"],
      "startServerCommand": "serve:lhci",
      "startServerReadyPattern": "Accepting connections at http://localhost:5000",
      "settings": {
         "onlyCategories": ["performance", "seo"]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
