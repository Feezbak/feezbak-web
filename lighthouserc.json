{
  "ci": {
    "collect": {
      "url": ["http://localhost:3000"],
      "startServerCommand": "serve:lhci",
      "startServerReadyPattern": "Accepting connections at http://localhost:3000",
      "settings": {
        "onlyCategories": [
          "performance",
          "seo",
          "best practice",
          "accessibility"
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
